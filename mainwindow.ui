  <property name="styleSheet">
   <string notr="true">/* ========== 1. 全局基础样式 ========== */
* {
    font-family: &quot;微软雅黑&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 16px;
}
QWidget 
{
    color: #c0d8f0;
}

QMainWindow#MainWindow
{
	background-color: #163250;
}
/*------------------- QMessageBox -------------------*/
QMessageBox 
{
    background-color: #1D4685;
    padding: 0px;
}

QMessageBox QLabel 
{
    font-size: 14px;
    padding: 10px;
}

QMessageBox QPushButton 
{
    background-color: #1a3b5f;
    border: 1px solid #2d5a8c;
    border-radius: 3px;
    padding: 4px 8px;
	color: white;
	min-width: 80px;
}

QMessageBox QPushButton:hover 
{
    background-color: #2d5a8c;
}

QMessageBox QPushButton:pressed 
{
    background-color: rgba(255,68,68,1);
    outline: none;
}
QMessageBox QPushButton:focus 
{
    outline: none;
}

/* 标题样式 */
QMessageBox QLabel#qt_msgbox_label {
    font-size: 16px;
    color: rgba(255,255,255,1);
    padding: 15px 10px 5px 10px;
}

/* 图标标签样式 */
QMessageBox QLabel#qt_msgboxex_icon_label {
    padding: 15px;
}

/* 设置消息框的图标颜色（通过资源图片或使用图标字体） */
/* 如果使用图标，可以这样设置： */
QMessageBox QCheckBox {
    color: #93c5fd;
    spacing: 5px;
}

QMessageBox QCheckBox::indicator {
    width: 16px;
    height: 16px;
}


/*-------------- 菜单整体样式QMenu -------------*/
QMenu
 {
	background-color: #F3F3F3;
    border: none;
    padding: 4px;
    color: black;
    font-size: 13px;
}

/* 菜单项 */
QMenu::item {
    padding: 3px 20px 3px 30px;  /* 上右下左 */
    margin: 2px;
    border-radius: 3px;
    min-width: 120px;
}

/* 菜单项悬停 */
QMenu::item:selected {
    background-color: #0066cc;
    color: white;
}

/* 菜单项禁用 */
QMenu::item:disabled {
    color: #888;
}

/* 分隔符 */
QMenu::separator {
    height: 1px;
    background-color: red;
    margin: 4px 10px;
}

/*======= QStatusBar =============*/
QStatusBar#statusbar
{
	background-color: #0b253d;
    border-top: 1px solid #2d5a8c;
    min-height: 24px;
}

QStatusBar#statusbar::item 
{
    border: none;
}




